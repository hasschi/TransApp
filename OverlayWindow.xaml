<Window x:Class="TransApp.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayWindow" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        WindowState="Normal">
    <Canvas Name="OverlayCanvas">
        <!-- 選取範圍提示框 -->
        <Rectangle Name="SelectionHighlight" 
                   Stroke="#8000FFFF" 
                   StrokeThickness="2" 
                   Fill="#1500FFFF" 
                   Visibility="Collapsed" />

        <!-- 翻譯文字容器 -->
        <Border Name="TranslationContainer" 
                Background="#CC222222" 
                CornerRadius="8" 
                BorderBrush="#44FFFFFF" 
                BorderThickness="1"
                Visibility="Collapsed"
                ClipToBounds="True"> <!-- 確保文字捲動時不會超出 Border -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <TextBlock x:Name="TranslatedText" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" 
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       LineStackingStrategy="BlockLineHeight"
                       Margin="0"
                       Padding="3"/> <!-- 減少 Padding 至 3px -->
        </Border>
    </Canvas>
</Window>
