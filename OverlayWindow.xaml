<Window x:Class="TransApp.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayWindow" Height="100" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Border Background="#CC222222" CornerRadius="8" BorderBrush="#44FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <TextBlock x:Name="TranslatedText" 
                   Text="翻譯內容將顯示在此..." 
                   Foreground="White" 
                   FontSize="18" 
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Padding="12"/>
    </Border>
</Window>
