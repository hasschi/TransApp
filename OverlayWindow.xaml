<Window x:Class="TransApp.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayWindow" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        WindowState="Normal">
    <Canvas Name="OverlayCanvas">
        <!-- 選取範圍提示框：淡藍色半透明邊框與背景 -->
        <Rectangle Name="SelectionHighlight" 
                   Stroke="#8000FFFF" 
                   StrokeThickness="2" 
                   Fill="#1500FFFF" 
                   Visibility="Collapsed" />

        <!-- 翻譯文字容器 -->
        <Border Name="TranslationContainer" 
                Background="#CC222222" 
                CornerRadius="8" 
                BorderBrush="#44FFFFFF" 
                BorderThickness="1"
                MaxWidth="400"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <TextBlock x:Name="TranslatedText" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" 
                       TextAlignment="Center"
                       Padding="12"/>
        </Border>
    </Canvas>
</Window>
